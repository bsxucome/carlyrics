<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#25384D"
                android:startColor="#344D66" />
            <stroke
                android:width="2dp"
                android:color="#587A97" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#26394E"
                android:startColor="#355168" />
            <stroke
                android:width="2dp"
                android:color="#6F9CC0" />
        </shape>
    </item>
</selector>

