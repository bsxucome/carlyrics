<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <ImageView
        android:id="@+id/backgroundArtworkView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.30"
        android:contentDescription="@string/artwork_desc"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_backdrop_scrim" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/permissionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/permission_title"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/permissionDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/permission_desc"
                android:textColor="#CCE7F7FF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/openPermissionButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_action_primary"
                android:text="@string/open_permission"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:layout_weight="0.37"
                android:background="@drawable/bg_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/artworkView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/artwork_desc"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.63"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:paddingLeft="22dp"
                android:paddingTop="18dp"
                android:paddingRight="22dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/titleView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="@string/default_title_companion"
                    android:textColor="@android:color/white"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/artistView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="1"
                    android:text="@string/default_artist_companion"
                    android:textColor="#EDF7FFFF"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/sourceView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:maxLines="1"
                    android:text="@string/default_source_companion"
                    android:textColor="#89BED8F3"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/retryLyricsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_action_secondary"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/retry_lyrics"
                        android:textAllCaps="false"
                        android:textColor="#D9F5FF"
                        android:textSize="10sp" />

                    <Button
                        android:id="@+id/disconnectButton"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_action_secondary"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/disconnect_phone_companion"
                        android:textAllCaps="false"
                        android:textColor="#D9F5FF"
                        android:textSize="10sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/lyricsStatusView"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_lyrics_chip"
                        android:gravity="center_vertical"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:text="@string/default_lyrics_status"
                        android:textColor="#B8DFF4"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/lyricsStage"
                    android:layout_width="match_parent"
                    android:layout_height="210dp"
                    android:layout_marginTop="18dp"
                    android:gravity="top"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/lyricLineTop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:textColor="#618EAC"
                        android:textSize="1sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/lyricLineUpper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:textColor="#89B2CC"
                        android:textSize="1sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/lyricLineCurrent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_horizontal"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="4dp"
                        android:maxLines="2"
                        android:minHeight="0dp"
                        android:paddingLeft="12dp"
                        android:paddingTop="0dp"
                        android:paddingRight="12dp"
                        android:paddingBottom="0dp"
                        android:shadowColor="#C4000000"
                        android:shadowDx="0"
                        android:shadowDy="4"
                        android:shadowRadius="18"
                        android:textColor="@android:color/white"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="260dp"
                        android:layout_height="2dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_lyric_divider" />

                    <TextView
                        android:id="@+id/lyricLineLower"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="2dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textColor="#B7D3E7"
                        android:textSize="26sp" />

                    <TextView
                        android:id="@+id/lyricLineBottom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="2dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="4dp"
                        android:textColor="#7697AF"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/diagnosticsView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="4"
                    android:text="@string/default_diagnostics"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="14dp"
            android:paddingRight="18dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/currentTimeView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginLeft="14dp"
                    android:layout_marginRight="14dp"
                    android:layout_weight="1"
                    android:max="1000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_track" />

                <TextView
                    android:id="@+id/totalTimeView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/previousButton"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_marginRight="28dp"
                    android:background="@drawable/bg_media_button_secondary"
                    android:contentDescription="@string/previous"
                    android:padding="19dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_skip_previous" />

                <ImageButton
                    android:id="@+id/playPauseButton"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginRight="28dp"
                    android:background="@drawable/bg_media_button_primary"
                    android:contentDescription="@string/play"
                    android:padding="24dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_play" />

                <ImageButton
                    android:id="@+id/nextButton"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:background="@drawable/bg_media_button_secondary"
                    android:contentDescription="@string/next"
                    android:padding="19dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_skip_next" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
