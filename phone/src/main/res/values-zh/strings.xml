<resources>
    <string name="app_name">手机歌词助手</string>
    <string name="service_label">手机歌词助手服务</string>
    <string name="companion_desc">这个应用运行在手机端，负责读取当前音乐会话、联网获取歌词，并通过蓝牙把歌曲信息同步到车机。</string>
    <string name="status_idle">状态：等待通知访问和蓝牙权限</string>
    <string name="status_ready">状态：已就绪，等待车机连接</string>
    <string name="status_permission_missing">状态：通知访问尚未开启</string>
    <string name="status_app_notifications_missing">状态：应用通知尚未开启</string>
    <string name="status_bluetooth_missing">状态：附近的设备（蓝牙）权限未开启</string>
    <string name="status_waiting_notification_access">状态：等待通知访问</string>
    <string name="status_notification_disconnected">状态：通知访问已断开</string>
    <string name="status_bluetooth_missing_runtime">状态：缺少附近的设备（蓝牙）权限</string>
    <string name="status_bluetooth_not_available">状态：当前设备不支持蓝牙</string>
    <string name="status_turn_on_bluetooth">状态：请先打开蓝牙，然后等待车机连接</string>
    <string name="status_bluetooth_server_failed">状态：无法打开蓝牙服务</string>
    <string name="status_connected_to">状态：已连接到 %1$s</string>
    <string name="status_waiting_reconnect">状态：等待车机重新连接</string>
    <string name="generic_phone_device">手机</string>
    <string name="connection_service_channel_name">手机助手连接服务</string>
    <string name="connection_service_channel_desc">保持蓝牙助手链路处于可连接状态。</string>
    <string name="connection_service_notification_title">手机歌词助手正在运行</string>
    <string name="connection_service_notification_text">蓝牙连接服务正在保持车机连接待命。</string>
    <string name="open_notification_access">打开通知访问</string>
    <string name="enable_app_notifications">启用应用通知</string>
    <string name="grant_bluetooth_permission">允许附近的设备（蓝牙）</string>
    <string name="how_it_works">使用说明</string>
    <string name="how_it_works_desc">1. 开启通知访问，让应用能读取当前音乐会话。\n2. 允许应用通知，并打开蓝牙权限。\n3. 将手机与车机完成蓝牙配对。\n4. 在车机端应用里连接这台手机。\n5. 在手机上开始播放音乐，助手会通过蓝牙同步封面、进度和歌词。</string>
</resources>
